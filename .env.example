# Rename to .env and fill in any keys your solution needs.
# We have accounts with these providers and will supply real keys when reviewing.

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
ELEVEN_LABS_API_KEY=xxxxx
GOOGLE_CLOUD_API_KEY=xxxxx
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-west-2

# LLM providers (all OpenAI-compatible). The factory uses the first key set, in
# order: OPENAI_API_KEY (above), then GITHUB_TOKEN, then OPENROUTER_API_KEY.
# GITHUB_TOKEN and OPENROUTER_API_KEY are not in the provided set above.
GITHUB_TOKEN=ghp_xxxxx
OPENROUTER_API_KEY=sk-or-xxxxx
